# ======================
# Database Configuration
# ======================
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=dev_colab

MYSQL_DB_URL=mysql+asyncmy://user:password@localhost:3306/dev_colab

# ======================
# JWT Authentication
# ======================
JWT_SECRET_KEY=your-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ======================
# Email (SMTP)
# ======================
MAIL_USERNAME=your-email@example.com
MAIL_PASSWORD=your-email-password
MAIL_FROM=your-email@example.com
MAIL_PORT=587
MAIL_SERVER=smtp.gmail.com

# ======================
# Pinecone (Vector DB)
# ======================
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_ENV=us-east-1
PINECONE_INDEX_NAME=profiles
PINECONE_PROJECTS_INDEX=projects

# ======================
# LLM / OpenRouter
# ======================
OPEN_ROUTER_API_KEY_2=your-openrouter-api-key
OPEN_ROUTER_API_KEY_4=your-openrouter-api-key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
MODEL_1=your-model-name

# ======================
# LangSmith (Optional)
# ======================
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# ======================
# Agent Collections
# ======================
TEAM_FORMATION_AGENT_COLLECTION_NAME=team_formation_checkpoints
PROJECT_PLANNER_AGENT_COLLECTION_NAME=project_planner_checkpoints

# ======================
# External Services
# ======================
PISTON_API_URL=http://localhost:2000/api/v2/execute

# ======================
# CORS Configuration
# ======================
# Comma-separated list of allowed origins. Use * for development.
# Example for production: https://your-frontend.com,https://admin.your-frontend.com
CORS_ORIGINS=*
